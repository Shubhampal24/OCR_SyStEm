# Configuration Template
# DO NOT place actual secrets in this file. Copy this to a file named '.env' and edit it there.

# Model Selection
# Recommended small models: Qwen/Qwen2.5-1.5B-Instruct, google/gemma-2-2b-it
LLM_MODEL_NAME="Qwen/Qwen2.5-1.5B-Instruct"

# OCR Settings
OCR_LANGUAGE="en"

# Environment
DEBUG_MODE=True
